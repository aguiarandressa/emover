{
  "name": "emover-site",
  "private": true,
  "version": "1.0.0",
  "description": "Site estático multipágina do Espaço Emover",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,md,json}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,md,json}\"",
    "lint:html": "python tools/lint_html.py",
    "check:contrast": "python tools/check_contrast.py",
    "lint:js": "eslint \"assets/js/**/*.js\"",
    "lint": "npm run lint:html && npm run lint:js",
    "lint:htmlhint": "htmlhint --config .htmlhintrc \"**/*.html\""
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "prettier": "^3.3.3",
    "eslint": "^9.20.1"
  }
}
